#!/bin/sh

# Skip hook in CI environments
[ -n "$CI" ] && exit 0

# Warn if pushing to main with no pending changesets
branch=$(git symbolic-ref --short HEAD 2>/dev/null)

if [ "$branch" = "main" ]; then
  changeset_count=$(ls .changeset/*.md 2>/dev/null | grep -v README.md | wc -l | tr -d ' ')
  if [ "$changeset_count" = "0" ]; then
    echo ""
    echo "⚠️  No pending changesets found."
    echo "   If you have unreleased changes, run: pnpm changeset"
    echo "   To push anyway: git push --no-verify"
    echo ""
    exit 1
  fi
fi
