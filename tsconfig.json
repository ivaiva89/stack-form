  "references": [
    { "path": "packages/core" },
    { "path": "packages/ui" },
    { "path": "packages/rhf" },
    { "path": "packages/tanstack" },
    { "path": "packages/native" },
    { "path": "packages/zod" },
    { "path": "packages/valibot" }
  ],
  "files": []
}
