{
  "name": "@stackform/rhf",
  "version": "0.0.1",
  "description": "React Hook Form adapter for StackForm",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "react-hook-form": ">=7",
    "@stackform/core": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "react-hook-form": "^7.72.1",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  }
}
