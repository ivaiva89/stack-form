{
  "name": "@stackform/zod",
  "version": "1.0.0",
  "description": "Zod validation integration for StackForm",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ivaiva89/stack-form.git",
    "directory": "packages/zod"
  },
  "keywords": [
    "react",
    "form",
    "stackform",
    "zod",
    "validation"
  ],
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "zod": ">=3.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "zod": "^4.3.6"
  }
}
