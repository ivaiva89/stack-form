{
  "name": "@stackform/ui",
  "version": "0.0.1",
  "description": "shadcn-based default slot implementations for StackForm",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "@radix-ui/react-label": ">=2",
    "class-variance-authority": ">=0.7",
    "clsx": ">=2",
    "tailwind-merge": ">=2"
  },
  "dependencies": {
    "@stackform/core": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "typescript": "^5.0.0",
    "tsup": "^8.0.0"
  }
}
